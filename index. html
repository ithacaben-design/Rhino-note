<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rhino Love Infinity</title>
    <style>
        body {
            margin: 0;
            background: #2c3e50;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            touch-action: manipulation;
        }

        .stack {
            position: relative;
            width: 200px;
            height: 200px;
        }

        .note-back {
            position: absolute;
            width: 200px;
            height: 200px;
            background: #7f8c8d;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.3);
            transform: rotate(-2deg);
        }

        .note-top {
            position: absolute;
            width: 200px;
            height: 200px;
            background: #bdc3c7; /* Solid Grey */
            box-shadow: 5px 5px 15px rgba(0,0,0,0.4);
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: sans-serif;
            font-weight: bold;
            font-size: 24px;
            color: #2c3e50;
            z-index: 10;
            user-select: none;
            text-align: center;
            transition: background 0.5s, color 0.5s;
        }

        /* Fixed Figure-8 Charge */
        @keyframes rhinoInfinity {
            0% { transform: translate(0, 0) scale(0.5) rotate(0deg); }
            25% { transform: translate(150px, -80px) scale(0.5) rotate(15deg); }
            50% { transform: translate(0, 0) scale(0.5) rotate(0deg); }
            75% { transform: translate(-150px, 80px) scale(0.5) rotate(-15deg); }
            100% { transform: translate(0, 0) scale(0.5) rotate(0deg); }
        }

        /* Simplified Rhino Fold */
        @keyframes foldToRhino {
            0% { transform: scale(1); clip-path: inset(0); }
            100% { 
                transform: scale(0.5); 
                /* Rugged Rhino Shape */
                clip-path: polygon(15% 45%, 35% 15%, 45% 45%, 90% 45%, 100% 95%, 0% 95%);
            }
        }

        .rhino-folded {
            animation: foldToRhino 1.2s forwards ease-in-out;
        }

        .infinity-charge {
            animation: rhinoInfinity 5s infinite ease-in-out;
            pointer-events: none;
        }
    </style>
</head>
