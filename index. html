<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Infinity Rhino Love</title>
    <style>
        body {
            margin: 0;
            background: #2c3e50;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            touch-action: manipulation;
        }

        .stack {
            position: relative;
            width: 200px;
            height: 200px;
        }

        /* Background notes in darker greys */
        .note-back {
            position: absolute;
            width: 200px;
            height: 200px;
            background: #7f8c8d;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.3);
            transform: rotate(-2deg);
        }

        /* Top Note - Modern Grey */
        .note-top {
            position: absolute;
            width: 200px;
            height: 200px;
            background: #bdc3c7; /* Classic Grey */
            box-shadow: 5px 5px 15px rgba(0,0,0,0.4);
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: sans-serif;
            font-weight: bold;
            font-size: 24px;
            color: #2c3e50;
            z-index: 10;
            user-select: none;
            text-align: center;
            transition: all 0.5s ease;
        }

        /* The Rhino Figure-8 Path */
        @keyframes rhinoInfinity {
            0% { transform: translate(0, 0) rotate(0deg) scale(0.5); }
            25% { transform: translate(180px, -80px) rotate(20deg) scale(0.5); }
            50% { transform: translate(0, 0) rotate(0deg) scale(0.5); }
            75% { transform: translate(-180px, 80px) rotate(-20deg) scale(0.5); }
            100% { transform: translate(0, 0) rotate(0deg) scale(0.5); }
        }

        /* The Initial Fold into Rhino Shape */
        @keyframes foldToRhino {
            0% { transform: scale(1); clip-path: inset(0); }
            100% { 
                transform: scale(0.5); 
                /* Rhino Silhouette Clip-Path */
                clip-path: polygon(10% 40%, 30% 10%, 40% 40%, 90% 40%, 100% 100%, 0% 100%);
            }
        }

        .rhino-shape {
            animation: foldToRhino 1.5s forwards ease-in-out;
        }

        .infinity-charge {
            animation: rhinoInfinity 5s infinite ease-in-out;
            pointer-events: none;
        }
    </style>
</head>
<body>

    <div class="stack">
        <div class="note-back" style="transform: rotate(3deg); background: #95a5a6;"></div>
        <div class="note-back"></div>
        <div id="topNote" class="note-top">Tap Me</div>
    </div>

    <script>
        const note = document.getElementById('topNote');
        let active = false;

        const startRhino = (e) => {
            if (active) return;
            active = true;
            if(e) e.preventDefault();

            // 1. Change text
            note.innerText = "I Love You";
            note.style.background = "#95a5a6"; // Darken slightly on tap
            note.style.color = "white";

            // 2. Fold into Rhino
            setTimeout(() => {
                note.innerText = "";
                note.classList.add('rhino-shape');
                
                // 3. Start the infinite figure-8 charge
                setTimeout(() => {
                    note.classList.remove('rhino-shape');
                    note.classList.add('infinity-charge');
                }, 1500);
            }, 1200);
        };

        note.addEventListener('click', startRhino);
        note.addEventListener('touchstart', startRhino, {passive: false});
    </script>
</body>
</html>
